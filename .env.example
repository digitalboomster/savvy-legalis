# Savvy Legalis — local & future API (never commit .env)

# Supabase (dashboard → Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
# For server JWT verify: Settings → API → JWT Secret (not the anon key)
SUPABASE_JWT_SECRET=

# Direct Postgres (use pooler in production; URL-encode special chars in password)
DATABASE_URL=postgresql+asyncpg://postgres:PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres
